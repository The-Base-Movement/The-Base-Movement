# Supabase — get these from your Supabase project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# TinyMCE — get your API key from https://www.tiny.cloud
VITE_TINYMCE_API_KEY=your-tinymce-api-key

# Sentry — get your DSN from https://sentry.io (Settings > Projects > Client Keys)
# Leave empty to disable error monitoring in development
VITE_SENTRY_DSN=

# GIS Integration — get your token from https://www.mapbox.com
# Leave empty to use fallback SVG visualization
VITE_MAPBOX_TOKEN=

# Umami Analytics — get from cloud.umami.is after adding your site
VITE_UMAMI_WEBSITE_ID=your-umami-website-id
# Umami share URL — Umami → your website → Settings → Share → enable → copy URL
VITE_UMAMI_SHARE_URL=

# Web Push — generate VAPID keys with: npx web-push generate-vapid-keys
# Only the PUBLIC key goes here. Private key + subject go into Supabase secrets only.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE EDGE FUNCTION SECRETS
# Set these via: Supabase Dashboard → Settings → Edge Function Secrets
# (Do NOT put these in .env — they are server-side only)
# ─────────────────────────────────────────────────────────────────────────────

# Resend — email dispatch for Urgent broadcasts (https://resend.com)
# RESEND_API_KEY=re_...

# MNotify — SMS dispatch (OTP, broadcasts, receipts, CSV imports) (https://developer.mnotify.com)
# MNOTIFY_API_KEY=your-mnotify-api-key
# MNOTIFY_SENDER_ID=THE BASE

# Web Push — VAPID private key + subject for push notifications
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_SUBJECT=mailto:hello@thebasemovement.info

# Hubtel — server-side payment initiation and callback
# HUBTEL_API_ID=your-hubtel-api-id
# HUBTEL_API_KEY=your-hubtel-api-key
# HUBTEL_ACCOUNT_NUMBER=your-hubtel-account-number
# Optional override if Hubtel provides a product-specific checkout endpoint
# HUBTEL_CHECKOUT_URL=https://payproxyapi.hubtel.com/items/initiate
# PUBLIC_SITE_URL=https://thebasemovement.info

# ─────────────────────────────────────────────────────────────────────────────
# ML INTELLIGENCE MICROSERVICE (ml-service/)
# Set to the URL where the FastAPI service is running.
# Local dev: http://localhost:8000
# Production: your VPS URL, e.g. https://ml.thebasemovement.info
# ─────────────────────────────────────────────────────────────────────────────
VITE_ML_SERVICE_URL=http://localhost:8000

